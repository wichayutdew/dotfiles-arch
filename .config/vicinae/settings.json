// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "pop_to_root_on_close": true,
   "escape_key_behavior": "",
   "favicon_service": "twenty",
   "font": {
      "normal": {
         "family": "JetBrainsMono Nerd Font Propo",
         "size": 10
      }
   },
   "theme": {
      "dark": {
         "name": "gruvbox-dark",
         "icon_theme": "Breeze"
      }
   },
   "launcher_window": {
      "compact_mode": {
         "enabled": true
      }
   },
   "providers": {
      "@Gelei/store.vicinae.bluetooth": {
         "preferences": {
            "connectionToggleable": true
         }
      },
      "@rastsislaux/store.vicinae.pulseaudio": {
         "entrypoints": {
            "inputDevices": {
               "enabled": true
            },
            "playback": {
               "enabled": false
            },
            "recording": {
               "enabled": false
            }
         }
      },
      "applications": {
         "entrypoints": {
            "avahi-discover": {
               "enabled": false
            },
            "bssh": {
               "enabled": false
            },
            "bvnc": {
               "enabled": false
            },
            "cmake-gui": {
               "enabled": false
            },
            "com.github.wwmm.easyeffects": {
               "enabled": true
            },
            "jconsole-java11-openjdk": {
               "enabled": false
            },
            "jshell-java11-openjdk": {
               "enabled": false
            },
            "lsp-plugins": {
               "enabled": false
            },
            "lstopo": {
               "enabled": false
            },
            "mpv": {
               "enabled": false
            },
            "nmgui": {
               "enabled": false
            },
            "nvim": {
               "enabled": false
            },
            "org.rncbc.qtractor": {
               "enabled": false
            },
            "qv4l2": {
               "enabled": false
            },
            "qvidcap": {
               "enabled": false
            },
            "vicinae": {
               "enabled": false
            },
            "vim": {
               "enabled": false
            },
            "xgps": {
               "enabled": false
            },
            "xgpsspeed": {
               "enabled": false
            },
            "yazi": {
               "enabled": false
            }
         }
      },
      "browser-extension": {
         "entrypoints": {
            "browse-tabs": {
               "enabled": false
            },
            "shortcut-active-tab": {
               "enabled": false
            }
         }
      },
      "clipboard": {
         "entrypoints": {
            "clear": {
               "enabled": false
            },
            "clear-history": {
               "enabled": false
            }
         }
      },
      "core": {
         "entrypoints": {
            "about": {
               "enabled": false
            },
            "documentation": {
               "enabled": false
            },
            "keybind-settings": {
               "enabled": false
            },
            "open-default-config": {
               "enabled": false
            },
            "reload-scripts": {
               "enabled": false
            },
            "report-bug": {
               "enabled": false
            },
            "search-emojis": {
               "preferences": {
                  "defaultAction": "copy",
                  "skinTone": "default"
               }
            },
            "settings": {
               "enabled": false
            },
            "sponsor": {
               "enabled": false
            }
         }
      },
      "developer": {
         "enabled": false
      },
      "manage-shortcuts": {
         "enabled": false
      },
      "power": {
         "entrypoints": {
            "hibernate": {
               "enabled": false
            },
            "lock": {
               "enabled": false
            },
            "suspend": {
               "enabled": false
            }
         }
      },
      "scripts": {
         "enabled": false
      },
      "shortcuts": {
         "enabled": false
      },
      "snippets": {
         "enabled": false
      },
      "system": {
         "entrypoints": {
            "run": {
               "enabled": false
            },
            "volume-down": {
               "enabled": false
            },
            "volume-up": {
               "enabled": false
            }
         }
      },
      "wm": {
         "enabled": false
      }
   }
}