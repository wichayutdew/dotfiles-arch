{
    "label" : "logout",
    "action" : "hyprshutdown || loginctl terminate-user $USER",
    "text" : "Logout",
    "keybind" : "l"
}

{
    "label" : "shutdown",
    "action" : "hyprshutdown -p 'systemctl poweroff' || systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "s"
}

{
    "label" : "reboot",
    "action" : "hyprshutdown -p 'systemctl reboot' || systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}

{
    "label" : "suspend",
    "action" : "hyprlock & sleep 0.5 && systemctl suspend",
    "text" : "Suspend",
    "keybind" : "u"
}
